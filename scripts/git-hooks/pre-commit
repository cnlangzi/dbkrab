#!/bin/bash
# dbkrab pre-commit hook
# Runs lint and tests before allowing commit
#
# To skip: SKIP_PRE_COMMIT=1 git commit ...

set -e

# Allow skipping
if [ "${SKIP_PRE_COMMIT:-0}" = "1" ]; then
    echo "⏭️  Skipping pre-commit checks (SKIP_PRE_COMMIT=1)"
    exit 0
fi

echo "🔍 Running pre-commit checks..."

# Get the directory of this script
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

cd "$PROJECT_ROOT"

# Ensure golangci-lint is installed
GOLANGCI_LINT="golangci-lint"
if command -v golangci-lint &> /dev/null; then
    echo "✅ golangci-lint found: $(golangci-lint --version | head -1)"
else
    # Try PATH that includes go/bin
    if [ -x "$HOME/go/bin/golangci-lint" ]; then
        export PATH="$PATH:$HOME/go/bin"
        echo "✅ golangci-lint found in ~/go/bin"
    elif [ -x "$(go env GOPATH)/bin/golangci-lint" ]; then
        export PATH="$PATH:$(go env GOPATH)/bin"
        echo "✅ golangci-lint found in GOPATH/bin"
    else
        echo "⚠️  golangci-lint not found, installing..."
        GOPROXY=https://goproxy.cn,direct go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.62.2
        export PATH="$PATH:$(go env GOPATH)/bin"
        echo "✅ golangci-lint installed: $(golangci-lint --version | head -1)"
    fi
fi

# Run vet
echo "📝 Running go vet..."
if ! make vet; then
    echo "❌ go vet failed. Please fix the issues before committing."
    exit 1
fi

# Run linter (only internal packages to avoid OOM with CGO deps)
echo "🔎 Running golangci-lint..."
if ! golangci-lint run --timeout=5m ./internal/...; then
    echo "❌ Lint failed. Fix issues or run: golangci-lint run --fix ./internal/..."
    exit 1
fi

# Run tests
echo "🧪 Running tests..."
if ! make test-short; then
    echo "❌ Tests failed. Please fix the issues before committing."
    exit 1
fi

echo "✅ All pre-commit checks passed!"
exit 0